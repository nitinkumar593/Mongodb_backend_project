<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Chats</title>
    <link rel="stylesheet" href="/css/new.css">
</head>
<body>
    <form method="post" action="/chats">
        <input type="text" name="from" placeholder="Enter from name">
        <textarea name="msg" placeholder="enter message" rows="10" cols="20"></textarea>
        <input type="text" name="to" placeholder="enter receiver name">
        <button>Submit</button>
    </form>
</body>
</html>