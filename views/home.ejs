<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Whatsapp</title>
    <link rel="stylesheet" href="/css/home.css">
</head>

<body>
    <h3>All Chats!</h3>
    <form action="http://localhost:8080/chats/new" method="get">
        <button>New Chat</button>
    </form>
    <% for(let chat of chats){ %>
        <div class="chat">
            <p>From : <%= chat.from %>
            </p>
            <div>
                <p>Message : <%= chat.msg %>
                </p>
                <form action="/chats/<%= chat._id %>/edit" method="get">
                    <button>Edit</button>
                </form>

            </div>

            <p>Received by : <%= chat.to %>
            </p>
            <p class="time">
                <%= chat.date?.toString().split(" ")[4] %></p>
            <p class=" date">
                    <%= chat.date?.toString().split(" ").slice(0,4).join(" ") %></p>

           <button class="delete-btn" data-id="<%= chat._id %>">Delete</button>

        </div>
   <%  } %>
</body>
</html